{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/livewire-starter-kit",
    "type": "project",
    "description": "The official Laravel starter kit for Livewire.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "cweagans/composer-patches": "^2.0",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.13.1",
        "livewire/livewire": "^4.1",
        "nativephp/mobile": "^3.2",
        "nativephp/mobile-background-tasks": "^0.0.3",
        "nativephp/mobile-device": "^1.0",
        "nativephp/mobile-firebase": "^1.1",
        "statum/native-scheduler": "@dev"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "nunomaduro/phpinsights": "^2.14",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Native\\Mobile\\Events\\PushNotification\\": "vendor/nativephp/mobile-firebase/src/Events/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@lint:check",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php -r \"if (file_exists('scripts/apply-nativephp-hotfixes.php')) { require 'scripts/apply-nativephp-hotfixes.php'; }\""
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/boost",
                "laravel/pail",
                "laravel/sail",
                "nunomaduro/collision",
                "nunomaduro/phpinsights",
                "pestphp/pest-plugin-laravel"
            ]
        },
        "patches": {
            "nativephp/mobile": {
                "Fix NativePHP background thread concurrent initialization crash": "patches/nativephp_ephemeral_mutex_v7.patch"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "nativephp-plugins",
            "type": "composer",
            "url": "https://plugins.nativephp.com"
        },
        {
            "name": "native-scheduler",
            "type": "path",
            "url": "packages/statum/native-scheduler",
            "options": {
                "symlink": false
            }
        }
    ]
}
