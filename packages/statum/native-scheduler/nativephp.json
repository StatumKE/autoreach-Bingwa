{
    "name": "statum/native-scheduler",
    "namespace": "BingwaEngine",
    "bridge_functions": [
        {
            "name": "TriggerSambaza",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.TriggerSambaza",
            "android_params": ["context"]
        },
        {
            "name": "ExecuteUssd",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.ExecuteUssd",
            "android_params": ["context"]
        },
        {
            "name": "SendSms",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.SendSms",
            "android_params": ["context"]
        },
        {
            "name": "RequestSetupPermissions",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.RequestSetupPermissions"
        },
        {
            "name": "CheckSetupStatus",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.CheckSetupStatus",
            "android_params": ["context"]
        },
        {
            "name": "UpdateIncomingSmsSettings",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.UpdateIncomingSmsSettings",
            "android_params": ["context"]
        },
        {
            "name": "RequestRuntimePermissions",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.RequestRuntimePermissions"
        },
        {
            "name": "OpenBatterySettings",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.OpenBatterySettings"
        },
        {
            "name": "OpenAccessibilitySettings",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.OpenAccessibilitySettings"
        },
        {
            "name": "OpenAppInfo",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.OpenAppInfo"
        },
        {
            "name": "OpenOverlaySettings",
            "android": "com.statum.plugins.nativescheduler.BingwaFunctions.OpenOverlaySettings"
        }
    ],
    "assets": {
        "android": {
            "android/res/xml/ussd_accessibility_service_config.xml": "res/xml/ussd_accessibility_service_config.xml",
            "android/res/values/ussd_accessibility_service_strings.xml": "res/values/ussd_accessibility_service_strings.xml"
        }
    },
    "android": {
        "min_version": 26,
        "dependencies": {
            "implementation": [
                "androidx.work:work-runtime-ktx:2.11.2",
                "com.squareup.okhttp3:okhttp:4.12.0"
            ]
        },
        "permissions": [
            "android.permission.POST_NOTIFICATIONS",
            "android.permission.CALL_PHONE",
            "android.permission.SEND_SMS",
            "android.permission.RECEIVE_SMS",
            "android.permission.READ_CONTACTS",
            "android.permission.READ_PHONE_STATE",
            "android.permission.SYSTEM_ALERT_WINDOW",
            "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
        ],
        "services": [],
        "receivers": [
            {
                "name": "com.statum.plugins.nativescheduler.BingwaIncomingSmsReceiver",
                "exported": true,
                "permission": "android.permission.BROADCAST_SMS",
                "intent_filters": [
                    {
                        "action": "android.provider.Telephony.SMS_RECEIVED"
                    }
                ]
            }
        ]
    },
    "ios": {
        "min_version": "15.0"
    }
}
