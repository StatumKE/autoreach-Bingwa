{
    "name": "statum/native-contacts",
    "description": "NativePHP contacts search plugin for Bingwa",
    "type": "nativephp-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Statum\\NativeContacts\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Statum\\NativeContacts\\NativeContactsServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    }
}
